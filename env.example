# Database
# For local Postgres (no SSL):
DATABASE_URL="postgresql://dev:dev@localhost:5432/getrandomtrip"
# For Neon or cloud Postgres with SSL, add ?sslmode=verify-full to silence the pg SSL warning, e.g.:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=verify-full"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3010"
NEXTAUTH_SECRET="6vyoLPW/gsoIG9/KfInXNJ09eJz3Ri20Q0oTrMtTOd4="

# NextAuth Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google OAuth Callback URL (add this to your Google Cloud Console)
# Authorized redirect URI: http://localhost:3010/api/auth/callback/google

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Payment Providers
STRIPE_PUBLIC_KEY="your-stripe-public-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"

# MercadoPago - Test Credentials (for development/testing)
MERCADOPAGO_TEST_ACCESS_TOKEN="your-mercadopago-test-access-token"
MERCADOPAGO_TEST_PUBLIC_KEY="your-mercadopago-test-public-key"
# Email of the MP *buyer* test user (from Developers → Test users). Must match who you log in as on checkout.
# The TESTUSER… value is a username id, not an email — without this, payer.email can mismatch and the Pay button stays disabled.
MERCADOPAGO_TEST_PAYER_EMAIL=""

# MercadoPago - Production Credentials (for live payments)
MERCADOPAGO_LIVE_ACCESS_TOKEN="your-mercadopago-live-access-token"
MERCADOPAGO_LIVE_PUBLIC_KEY="your-mercadopago-live-public-key"

# Email Service
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Analytics
NEXT_PUBLIC_GA_ID="your-google-analytics-id"

# Google Tag Manager — same container for main site and subdomains (e.g. investors.getrandomtrip.com). Filter by Page Hostname in GTM.
NEXT_PUBLIC_GTM_ID=""

# Unsplash API (for city/country images)
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY="your-unsplash-access-key"

# Environment
NODE_ENV="development"

# Netlify Blobs (tripper blog images via /api/tripper/blog-media)
# Set automatically on Netlify. For local uploads with Blobs, use `netlify dev` or set:
# NETLIFY_SITE_ID="your-site-id"
# NETLIFY_AUTH_TOKEN="your-personal-access-token"

# Discord Bot Configuration (for community server setup)
# Get bot token from: https://discord.com/developers/applications
# Get guild ID: Right-click your server name → Copy Server ID (requires Developer Mode enabled)
DISCORD_BOT_TOKEN="your-discord-bot-token"
DISCORD_GUILD_ID="your-discord-server-id"

# Website URL (for Discord welcome messages)
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3010"
